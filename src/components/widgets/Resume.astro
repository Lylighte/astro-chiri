---
import type { ResumeData } from '@/types'

interface Props {
  data: ResumeData
}

const { data } = Astro.props
const { basics, experience, activity, certificates, interests, links } = data

const fmtDate = (s: string) => {
  const [y, m] = s.split('-')
  const monthNames = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec']
  return `${monthNames[parseInt(m, 10) - 1]} ${y}`
}

const isPresent = (s: string) => {
  if (s === '至今' || s === 'Present') return true
  const now = new Date()
  const [y, m] = s.split('-')
  const d = new Date(parseInt(y, 10), parseInt(m, 10) - 1)
  return d >= new Date(now.getFullYear(), now.getMonth())
}

const dateRange = (start: string, end: string) =>
  `${fmtDate(start)} – ${isPresent(end) ? 'Present' : fmtDate(end)}`
---

<div class="resume prose">
  <!-- ── Header ── -->
  <header class="resume-header">
    <h1 class="resume-name">{basics.name}</h1>
    {basics.label && <p class="resume-label">{basics.label}</p>}
    <div class="resume-contact">
      {basics.email && <a href={`mailto:${basics.email}`}>{basics.email}</a>}
      {basics.website && <a href={basics.website} target="_blank" rel="noopener noreferrer">{basics.website.replace(/^https?:\/\//, '')}</a>}
    </div>
    {basics.summary && <p class="resume-summary">{basics.summary}</p>}
    {basics.skills && basics.skills.length > 0 && (
      <p class="resume-skills"><span class="label">Skills: </span>{basics.skills.join(' · ')}</p>
    )}
  </header>

  <!-- ── Experience (incl. education) ── -->
  {experience && experience.length > 0 && (
    <section class="resume-section">
      <h2>Experience</h2>
      {experience.map((item) => (
        <div class="resume-item">
          <div class="item-header">
            <span class="item-title">{item.title}</span>
            <span class="item-date">{dateRange(item.startDate, item.endDate)}</span>
          </div>
          <div class="item-subtitle">{item.organization}</div>
          {item.highlights && item.highlights.length > 0 && (
            <ul class="item-details">{item.highlights.map((h) => <li>{h}</li>)}</ul>
          )}
        </div>
      ))}
    </section>
  )}

  <!-- ── Certificates & Awards ── -->
  {certificates && certificates.length > 0 && (
    <section class="resume-section">
      <h2>Certificates &amp; Awards</h2>
      {certificates.map((item) => (
        <div class="resume-item">
          <div class="item-header">
            <span class="item-title">{item.name}</span>
            <span class="item-date">{fmtDate(item.date)}</span>
          </div>
          {item.issuer && <div class="item-subtitle">{item.issuer}</div>}
        </div>
      ))}
    </section>
  )}

  <!-- ── Activity ── -->
  {activity && activity.length > 0 && (
    <section class="resume-section">
      <h2>Activity</h2>
      {activity.map((item) => (
        <div class="resume-item">
          <div class="item-header">
            <span class="item-title">{item.role}</span>
            <span class="item-date">{dateRange(item.startDate, item.endDate)}</span>
          </div>
          <div class="item-subtitle">{item.organization}</div>
          {item.highlights && item.highlights.length > 0 && (
            <ul class="item-details">{item.highlights.map((h) => <li>{h}</li>)}</ul>
          )}
        </div>
      ))}
    </section>
  )}

  <!-- ── Interests ── -->
  {interests && interests.length > 0 && (
    <section class="resume-section">
      <h2>Interests</h2>
      <div class="interests-list">
        {interests.map((interest) => (
          <div class="interest-line">
            <span class="interest-name">{interest.name}</span>
            <span class="interest-items">{interest.keywords?.join(' · ')}</span>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- ── Links ── -->
  {links && links.length > 0 && (
    <section class="resume-section">
      <h2>Links</h2>
      <div class="links-list">
        {links.map((link) => (
          <a class="link-item" href={link.url} target="_blank" rel="noopener noreferrer">{link.label}</a>
        ))}
      </div>
    </section>
  )}
</div>

<style>
  .resume { margin-bottom: 8rem; }

  /* ── Header ── */
  .resume-header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }
  .resume-name {
    font-size: var(--font-size-l);
    font-weight: var(--font-weight-bold);
    margin: 1rem 0 0 0;
    line-height: 1.4;
  }
  .resume-label {
    color: var(--text-secondary);
    margin: 0rem 0 0 0;
  }
  .resume-contact {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.25rem;
    margin: 0.5rem 0 0 0;
    font-size: var(--font-size-s);
  }
  .resume-contact a {
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.2s;
  }
  .resume-contact a:hover {
    color: var(--text-primary);
    text-decoration: underline;
  }
  .resume-summary {
    margin: 0.5rem 0 0 0;
    line-height: 1.75;
  }
  .resume-skills {
    margin: 0.5rem 0 0 0;
    line-height: 1.75;
    font-size: var(--font-size-s);
    color: var(--text-secondary);
  }
  .resume-skills .label {
    font-weight: var(--font-weight-bold);
    color: var(--text-primary);
  }

  /* ── Sections ── */
  .resume-section {
    margin-top: 0.5rem;
    margin-bottom: 0.5rem;
  }

  /* ── Items ── */
  .resume-item { margin-bottom: 1rem; }
  .resume-item:last-child { margin-bottom: 0; }
  .item-header {
    display: flex; justify-content: space-between; align-items: baseline;
    flex-wrap: wrap; gap: 0.25rem 0.75rem;
  }
  .item-title {
    font-weight: var(--font-weight-bold);
    /* margin: 0 0 0 0; */
  }
  .item-title a { color: var(--text-primary); }
  .item-date {
    font-size: var(--font-size-s); color: var(--text-secondary);
    white-space: nowrap; font-variant-numeric: tabular-nums;
  }
  .item-subtitle { font-size: var(--font-size-s); color: var(--text-secondary); margin: 0.2rem 0 0.2rem 0; }
  .item-desc { margin: 0.25rem 0 0.35rem 0; line-height: 1.75; }
  .item-tags {
    font-size: var(--font-size-s); color: var(--text-secondary);
    margin: 0.35rem 0 0 0;
  }
  .item-details {
    margin: 0.2rem 0 0 0; padding-left: 1.15rem; list-style: none;
  }
  .item-details li {
    position: relative; font-size: var(--font-size-s);
    color: var(--text-secondary); line-height: 1.6; margin-bottom: 0.05rem;
  }
  .item-details li::before {
    content: '·'; position: absolute; left: -0.85rem; color: var(--text-tertiary);
  }

  /* ── Interests ── */
  .interests-list { margin-bottom: 1.25rem; }
  .interest-line {
    display: flex; flex-wrap: wrap; align-items: baseline;
    gap: 0.4rem 0.6rem; line-height: 1.75;
  }
  .interest-name {
    font-weight: var(--font-weight-bold);
    min-width: 7.5rem;
  }
  .interest-items {
    font-size: var(--font-size-s); color: var(--text-secondary);
  }

  /* ── Links ── */
  .links-list {
    display: flex; flex-wrap: wrap; gap: 0.75rem;
  }
  .link-item {
    font-size: var(--font-size-s);
    color: var(--text-secondary);
    text-decoration: underline;
    text-decoration-color: var(--text-tertiary);
    transition: color 0.2s, text-decoration-color 0.2s;
  }
  .link-item:hover {
    color: var(--text-primary);
    text-decoration-color: var(--text-primary);
  }

  @media print {
    .resume-name { font-size: var(--font-size-l); }
    .resume-section { break-inside: avoid; }
  }
</style>

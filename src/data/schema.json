{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "description": "Personal resume data schema — informal, personality-first",
  "properties": {
    "basics": {
      "type": "object",
      "description": "Basic personal information",
      "properties": {
        "name": { "type": "string", "description": "Full name" },
        "label": { "type": "string", "description": "Title/headline (can be empty)" },
        "email": { "type": "string", "format": "email", "description": "Email address" },
        "website": { "type": "string", "format": "uri", "description": "Personal website URL" },
        "summary": { "type": "string", "description": "Brief personal intro — show your vibe" },
        "skills": { "type": "array", "description": "Flat list of skills, no categories", "items": { "type": "string" } }
      },
      "required": ["name", "summary"]
    },
    "experience": {
      "type": "array",
      "description": "Work experience & education entries (education also goes here)",
      "items": {
        "type": "object",
        "properties": {
          "title": { "type": "string", "description": "Role, e.g. 'Frontend Intern' or 'B.Eng in ...'" },
          "organization": { "type": "string", "description": "Company / lab / university name" },
          "startDate": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}$" },
          "endDate": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}$" },
          "highlights": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["title", "organization", "startDate", "endDate"]
      }
    },
    "activity": {
      "type": "array",
      "description": "Student org / club / community involvement — renders in the Interests section",
      "items": {
        "type": "object",
        "properties": {
          "role": { "type": "string" },
          "organization": { "type": "string" },
          "startDate": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}$" },
          "endDate": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}$" },
          "highlights": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["role", "organization", "startDate", "endDate"]
      }
    },
    "certificates": {
      "type": "array",
      "description": "Certificates & awards combined",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "issuer": { "type": "string" },
          "date": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}$" },
          "url": { "type": "string", "format": "uri" }
        },
        "required": ["name", "date"]
      }
    },
    "publications": {
      "type": "array",
      "description": "Published papers / articles (reserved for future use)",
      "items": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "authors": { "type": "string" },
          "venue": { "type": "string" },
          "year": { "type": "string" },
          "url": { "type": "string", "format": "uri" }
        },
        "required": ["title", "venue", "year"]
      }
    },
    "interests": {
      "type": "array",
      "description": "Hobbies & personal interests",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "keywords": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["name"]
      }
    },
    "links": {
      "type": "array",
      "description": "Link list — social profiles, bookmarks, etc.",
      "items": {
        "type": "object",
        "properties": {
          "label": { "type": "string" },
          "url": { "type": "string", "format": "uri" }
        },
        "required": ["label", "url"]
      }
    }
  },
  "required": ["basics"]
}

---
import IndexLayout from '@/layouts/IndexLayout.astro'
import ResumeWidget from '@/components/widgets/Resume.astro'
import { themeConfig } from '@/config'
import type { ResumeData } from '@/types'

// Import resume data — this is the single source of truth.
// Edit src/data/resume.json to update your resume.
const resumeData: ResumeData = (await import('@/data/resume.json')).default
---

<IndexLayout title={`Resume · ${themeConfig.site.title}`} description={`Resume of ${resumeData.basics.name}`}>
  <main>
    <ResumeWidget data={resumeData} />
  </main>
</IndexLayout>
